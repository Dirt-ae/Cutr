# Bunny.net Configuration
BUNNY_API_KEY=replace-with-your-bunny-api-key
BUNNY_LIBRARY_ID=replace-with-your-bunny-library-id
BUNNY_CDN_HOST=replace-with-your-bunny-cdn-host

# JWT Secret (change in production)
JWT_SECRET=replace-with-at-least-32-random-bytes

# Admin bootstrap account (required)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-12-plus-character-password

# Password hashing cost (10-15)
BCRYPT_ROUNDS=12

# Server
PORT=3001
